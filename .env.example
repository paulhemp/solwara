# Copy to .env.local for local dev with `vercel dev`, and add the same values
# in Vercel → Project → Settings → Environment Variables for production.
# NEVER commit real keys.

# Required — your Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — verified sender. Defaults to Resend's test address until you
# verify solwara.com.au in Resend (https://resend.com/domains).
# Once verified, set this to your domain address:
RESEND_FROM=Solwara <hello@solwara.com.au>

# Optional — where contact / wholesale / subscriber notifications are sent.
CONTACT_TO=paulbenhaim@gmail.com

# ---- PayPal ----------------------------------------------------------------
# Required — your PayPal app SECRET (https://developer.paypal.com → Apps).
# NEVER commit this or expose it in the browser.
PAYPAL_CLIENT_SECRET=your-paypal-secret-here

# Optional — your PayPal Client ID. It's public (ships in the browser SDK) and
# already has a default baked in; override here only if you rotate it.
# PAYPAL_CLIENT_ID=AT...

# Optional — "live" (default) or "sandbox". MUST match the credentials above.
PAYPAL_ENV=live
